{
  "private": true,
  "name": "scenic-route",
  "version": "0.1.0",
  "author": "Erik Brinkman <erik.brinkman@gmail.com>",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "fmt": "biome format --write && biome check --write && cargo fmt",
    "lint": "tsc && biome check && cargo fmt --check && cargo clippy -- -D warnings",
    "dev": "bun run build-tiles && next dev --turbopack",
    "export": "bun run build-tiles && next build",
    "start": "next start",
    "set-admin": "bun run scripts/set-admin.ts",
    "build-tree-data": "bun run scripts/build-tree-data.ts",
    "build-buildings": "bun run scripts/buildings.ts",
    "build-dining": "bun run scripts/dining.ts",
    "build-openstreets": "bun run scripts/openstreets.ts",
    "build-landuse": "bun run scripts/landuse.ts",
    "build-commercial": "bun run scripts/build-commercial.ts",
    "build-tiles": "bun run scripts/build-street-tiles.ts"
  },
  "dependencies": {
    "firebase": "^12.16.0",
    "leaflet": "^1.9.4",
    "next": "^16.2.10",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.7.0",
    "react-leaflet": "^5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "firebase-admin": "^14.1.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3"
  }
}
