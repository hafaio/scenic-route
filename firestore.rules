rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // Shared pin collection. All admins read & write the same set; the admin
    // claim is set via the Firebase Admin SDK (see scripts/set-admin.ts).
    match /pins/{pinId} {
      allow read: if isAdmin();
      allow create: if isAdmin()
        && request.resource.data.creator == request.auth.uid
        && request.resource.data.lastModifier == request.auth.uid;
      allow update: if isAdmin()
        && request.resource.data.creator == resource.data.creator
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.lastModifier == request.auth.uid;
      allow delete: if isAdmin();
    }
  }
}
